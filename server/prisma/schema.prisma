// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlaidItem {
  id              String   @id @default(cuid())
  userId          Int      @unique      // Int to match User.id
  accessToken     String
  itemId          String   @unique
  institutionName String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  // Primary Key
  id        Int      @id @default(autoincrement())

  // User Information
  name      String
  email     String   @unique
  password  String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One User -> Many Subscriptions
  subscriptions Subscription[]

  // One User -> One PlaidItem (optional — only if they connect a bank)
  plaidItem     PlaidItem?
  
  // One User -> Many Notifications
  notifications Notification[]
}

model Subscription {
  // Primary Key
  id                   Int      @id @default(autoincrement())

  // Subscription Details
  platformName         String
  category             String

  // Financial Information
  price                Float
  currency             String

  // Billing Information
  billingCycle         String
  startDate            DateTime
  renewalDate          DateTime

  // Reminder Settings
  reminderDaysBefore   Int

  // Payment Details
  paymentMethod        String
  paymentProvider      String

  // Subscription Status
  status               String

  // Source of Subscription
  // Example: MANUAL or PLAID
  subscriptionSource   String

  // Optional: Plaid Stream ID to prevent duplicates if user syncs again
  plaidStreamId        String?  @unique

  // Foreign Key
  userId               Int

  // Many Subscriptions -> One User
  user                 User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  // One Subscription -> Many Notifications
  notifications        Notification[]
}


// This creates a new table in PostgreSQL to store notifications
model Notification {
  // Every notification gets a unique ID number
  id          Int      @id @default(autoincrement())
  
  // The actual text the user will read (e.g. "Netflix renews tomorrow!")
  message     String
  
  // True if the user has seen it, False if it's unread. Defaults to False.
  isRead      Boolean  @default(false)
  
  // The category of the notification (e.g., "RENEWAL_ALERT")
  type        String   
  
  // This links the notification to a specific User. 
  // If the user is deleted, their notifications are deleted too (Cascade).
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // This optionally links the notification to the specific subscription.
  // We use Int? (optional) because some notifications might not be about a subscription.
  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  // Records exactly when the notification was generated
  createdAt   DateTime @default(now())
}
